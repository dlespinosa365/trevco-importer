APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Use redis in production with Laravel Horizon. Local sqlite testing often keeps database or sync.
QUEUE_CONNECTION=database

# Flow jobs use ShouldQueueAfterCommit; keep true so dispatches wait for open DB transactions (schedules, etc.).
# DB_QUEUE_AFTER_COMMIT=true
# REDIS_QUEUE_AFTER_COMMIT=true

# Longest expected single step (seconds), e.g. NetSuite order import (~5 min). Drives default queue retry_after
# lease and ExecuteIntegrationStepJob timeout ($tries stays 1 — steps are not retried by the framework).
# FLOW_LONGEST_STEP_SECONDS=300

# Hourly maintenance: mark RUNNING executions stale past this many minutes (see routes/console.php).
# FLOW_RECONCILE_STALE_ENABLED=true
# FLOW_RECONCILE_STALE_MINUTES=180

# Optional override for Redis/database lease (seconds). Default = max(480, FLOW_LONGEST_STEP_SECONDS + 180).
# DB_QUEUE_RETRY_AFTER=
# REDIS_QUEUE_RETRY_AFTER=

# Filament admin (db:seed creates this user; override password in production)
# FILAMENT_ADMIN_EMAIL=admin@example.com
# FILAMENT_ADMIN_PASSWORD=

# Disk flows (integrations/): optional failure notification targets per integration config
# FLOWS_FAILURE_MAIL=
# FLOWS_FAILURE_SLACK_WEBHOOK=
# FLOWS_FAILURE_TEAMS_WEBHOOK=
# TEAMS_WEBHOOK_URL=   # optional default for Osama\LaravelTeamsNotification when not passing URL per call
# FLOW_MAX_STEPS=500

# Throttle for DiskFlowContext::heartbeat() (seconds); use 0 only if you know what you are doing
# FLOW_HEARTBEAT_INTERVAL_SECONDS=60

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_QUEUE_CONNECTION=default

#
# Laravel Horizon (workers on Linux/WSL/Docker: requires PHP ext-pcntl and ext-posix; not available on Windows CLI).
# Production: QUEUE_CONNECTION=redis, run "php artisan horizon".
# Dashboard: /horizon (after Filament login as admin). Tune processes if NetSuite governance limits concurrency.
#
# HORIZON_PATH=horizon
# HORIZON_FLOWS_MIN_PROCESSES=2
# HORIZON_FLOWS_MAX_PROCESSES=12
# HORIZON_FLOWS_TIMEOUT=600
# HORIZON_FLOWS_MEMORY=256
# HORIZON_GENERAL_MAX_PROCESSES=4
# HORIZON_GENERAL_TIMEOUT=120

# Long queue wait alerts (Horizon); thresholds are config/horizon.php -> waits
# HORIZON_NOTIFICATIONS_MAIL=ops@example.com
# HORIZON_NOTIFICATIONS_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# HORIZON_NOTIFICATIONS_SLACK_CHANNEL=#queues
# HORIZON_NOTIFICATIONS_SMS=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
